# Required
SECRET_KEY="your-secure-secret-key"

# JWT Secret Key (used for email verification tokens)
JWT_SECRET_KEY="your-secure-jwt-secret-key"

# Resend API Key (for sending emails)
RESEND_API_KEY="re_your_resend_api_key_here"

# Email sender address (must be verified in Resend)
MAIL_FROM="info@miminions.ai"

# Contact form recipient
CONTACT_EMAIL="info@miminions.ai"

# Redis URL for Flask-Limiter backend (recommended in production)
# Example (AWS ElastiCache/Redis):
# REDIS_URL="redis://localhost:6379/0"
REDIS_URL=""

# Environment (local or production)
# Set to "production" to use AWS DynamoDB + Redis limiter backend.
# Use "local" for local JSON database and in-memory limiter storage.
FLASK_ENV="local"

# AWS Region
AWS_REGION="us-east-2"

# AWS Credentials (optional — only needed for local development)
# On AWS Elastic Beanstalk / EC2, IAM roles are used automatically.
#AWS_ACCESS_KEY_ID="your-aws-access-key"
#AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
